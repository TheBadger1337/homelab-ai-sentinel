GEMINI_TOKEN=AIza...
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGhIjK...
TELEGRAM_CHAT_ID=987654321
NTFY_URL=https://ntfy.sh/your-topic
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_TO=you@gmail.com
WHATSAPP_TOKEN=EAAxxxxxxx...
WHATSAPP_PHONE_ID=123456789012345
WHATSAPP_TO=15551234567
# Signal requires docker compose --profile signal up to start the signal-cli-rest-api container.
SIGNAL_API_URL=http://signal-cli-rest-api:8080
SIGNAL_SENDER=+15551234567
SIGNAL_RECIPIENT=+15551234567
GOTIFY_URL=http://gotify:80
GOTIFY_APP_TOKEN=your-app-token
MATRIX_HOMESERVER=https://matrix.org
MATRIX_ACCESS_TOKEN=syt_your_access_token
MATRIX_ROOM_ID=!yourRoomId:matrix.org
# iMessage via Bluebubbles — requires a Mac running the Bluebubbles server app
# https://bluebubbles.app — NOT testable without Apple hardware
IMESSAGE_URL=http://your-mac.local:1234
IMESSAGE_PASSWORD=your-bluebubbles-password
IMESSAGE_TO=+15551234567
# ---------------------------------------------------------------------------
# Platform disable switches — set to "true" to silence a platform without
# removing its credentials. Useful when testing a single platform or
# temporarily taking one offline. All platforms default to enabled.
# ---------------------------------------------------------------------------
# DISCORD_DISABLED=false
# SLACK_DISABLED=false
# TELEGRAM_DISABLED=false
# NTFY_DISABLED=false
# EMAIL_DISABLED=false
# WHATSAPP_DISABLED=false
# SIGNAL_DISABLED=false
# GOTIFY_DISABLED=false
# MATRIX_DISABLED=false
# IMESSAGE_DISABLED=false

# Debug mode — verbose logging: full parsed alert, AI response, per-platform results.
# Never enable in production — debug output includes alert payloads with hostnames/URLs.
# SENTINEL_DEBUG=false

# ---------------------------------------------------------------------------
# Security & rate-limiting
# ---------------------------------------------------------------------------

# Webhook authentication — strongly recommended for internet-facing deployments.
# All POST /webhook requests must include header: X-Webhook-Token: your_secret_here
# Generate: openssl rand -hex 32
# WEBHOOK_SECRET=

# Webhook rate limiter — sliding window counter (default: disabled).
# Set WEBHOOK_RATE_LIMIT > 0 to enable. Useful for internet-facing setups.
# Example: 60 requests per 60-second window (1 req/s average)
# WEBHOOK_RATE_LIMIT=0
# WEBHOOK_RATE_WINDOW=60

# Deduplication — suppress identical alerts within this window (seconds).
# Identical = same service + status + message. Set to 0 to disable.
# DEDUP_TTL_SECONDS=60

# ---------------------------------------------------------------------------
# AI provider rate limits & retry
# ---------------------------------------------------------------------------

# Gemini model name — override if Google releases a versioned model name.
# GEMINI_MODEL=gemini-2.5-flash

# Gemini RPM (requests per minute) limiter.
# Default 10 matches the free tier limit. Raise if you're on a paid plan.
# Free tier:  10 RPM, 500 RPD, 1M TPM  → https://ai.google.dev/gemini-api/docs/rate-limits
# Tier 1:    2000 RPM, 1T  TPD         → https://ai.google.dev/gemini-api/docs/rate-limits
# Set to 0 to disable the limiter entirely.
# GEMINI_RPM=10

# Retry on 429 / 5xx from the Gemini API (default: 2 retries).
# Backoff doubles each retry: 1s → 2s → 4s (with GEMINI_RETRY_BACKOFF=1.0).
# GEMINI_RETRIES=2
# GEMINI_RETRY_BACKOFF=1.0

# ---------------------------------------------------------------------------
# Gunicorn performance tuning
# ---------------------------------------------------------------------------

# Worker processes (default: cpu_count + 1, auto-detected).
# Each worker is an independent process. More workers = more concurrent requests.
# For a 2-core homelab server the default is 3 workers.
# WORKERS=3

# Threads per worker (default: 4, gthread worker class).
# Each thread handles one concurrent request within the worker process.
# 3 workers × 4 threads = 12 concurrent request slots (default on 2-core).
# WORKER_THREADS=4

# Recycle workers after N requests. Prevents memory growth from any leaks.
# GUNICORN_MAX_REQUESTS=1000

# Worker kill timeout in seconds. Must exceed worst-case request time (~48s with
# default retries). If you raise GEMINI_RETRIES or GEMINI_RETRY_BACKOFF, raise this too.
# GUNICORN_TIMEOUT=60

# Access log: set to "-" to write per-request access logs to stdout.
# Off by default — application-level logging covers what you need for a homelab.
# GUNICORN_ACCESS_LOG=

# Optional: port override (default 5000)
PORT=5000
