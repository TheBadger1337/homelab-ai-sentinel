# ===========================================================================
# Homelab AI Sentinel — Configuration Reference
# ===========================================================================
# Copy this file to .secrets.env and uncomment/set the values you need.
# Only uncomment what you actually use — every feature is opt-in.
#
# FEATURE DEPENDENCY MAP
# ----------------------
# Sentinel has three tiers. Each tier works independently:
#
#   Tier 1: Stateless (default — no DB, no UI)
#     What works: parse → threshold → AI insight → dispatch
#     What you get: webhook receives alerts, optional AI enrichment, notifications
#     What you DON'T get: alert history, dedup across restarts, rate limiting,
#                         cooldown, escalation, DLQ retry, incidents, web UI
#
#   Tier 2: Stateless + DB (set DB_PATH to a writable path)
#     Adds: alert logging, dedup L2 (cross-worker), rate limiting, cooldown,
#           severity escalation, dead letter queue, incidents, correlation,
#           pulse stats, housekeeper
#     Threat model addition: SQLite file on disk contains alert payloads,
#           AI responses, and service names. Protect the volume.
#
#   Tier 3: Stateless + DB + Web UI (set DB_PATH + UI_PASSWORD)
#     Adds: browser dashboard, incident timeline, topology view, SSE stream
#     Threat model addition: HTTP session cookies, additional attack surface
#           on /api/* endpoints. Session auth is independent from webhook HMAC.
#
# To explicitly disable DB (and all Tier 2/3 features at once):
#   DB_DISABLED=true
#
# ===========================================================================


# ---------------------------------------------------------------------------
# Tier 1: Core — notification platforms (no DB required)
# ---------------------------------------------------------------------------
# Configure one or more platforms. Unconfigured platforms are silently skipped.
# Disable a configured platform without removing credentials: {PLATFORM}_DISABLED=true

GEMINI_TOKEN=AIza...
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGhIjK...
TELEGRAM_CHAT_ID=987654321
NTFY_URL=https://ntfy.sh/your-topic
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_TO=you@gmail.com
WHATSAPP_TOKEN=EAAxxxxxxx...
WHATSAPP_PHONE_ID=123456789012345
WHATSAPP_TO=15551234567
# Signal requires docker compose --profile signal up to start the signal-cli-rest-api container.
SIGNAL_API_URL=http://signal-cli-rest-api:8080
SIGNAL_SENDER=+15551234567
SIGNAL_RECIPIENT=+15551234567
GOTIFY_URL=http://gotify:80
GOTIFY_APP_TOKEN=your-app-token
MATRIX_HOMESERVER=https://matrix.org
MATRIX_ACCESS_TOKEN=syt_your_access_token
MATRIX_ROOM_ID=!yourRoomId:matrix.org
# iMessage via Bluebubbles — requires a Mac running the Bluebubbles server app
# https://bluebubbles.app — NOT testable without Apple hardware
IMESSAGE_URL=http://your-mac.local:1234
IMESSAGE_PASSWORD=your-bluebubbles-password
IMESSAGE_TO=+15551234567

# Platform disable switches — silence a platform without removing credentials.
# DISCORD_DISABLED=false
# SLACK_DISABLED=false
# TELEGRAM_DISABLED=false
# NTFY_DISABLED=false
# EMAIL_DISABLED=false
# WHATSAPP_DISABLED=false
# SIGNAL_DISABLED=false
# GOTIFY_DISABLED=false
# MATRIX_DISABLED=false
# IMESSAGE_DISABLED=false


# ---------------------------------------------------------------------------
# Tier 1: Core — operating mode (no DB required, but predictive benefits from DB)
# ---------------------------------------------------------------------------
# Controls how much of the AI pipeline runs per alert.
#   minimal    — parse, scan, filter, dispatch; NO AI call (fastest, zero tokens)
#   reactive   — AI insight per alert, no history context (works without DB)
#   predictive — AI insight + recent alert history + pulse stats (default)
#                History and pulse require DB. Without DB, predictive still works
#                but the AI has no history to reference — equivalent to reactive.
# SENTINEL_MODE=predictive

# Debug mode — verbose logging: full parsed alert, AI response, per-platform results.
# Never enable in production — debug output includes alert payloads with hostnames/URLs.
# SENTINEL_DEBUG=false


# ---------------------------------------------------------------------------
# Tier 1: Core — security (no DB required)
# ---------------------------------------------------------------------------

# Webhook authentication — strongly recommended for internet-facing deployments.
# All POST /webhook requests must include header: X-Webhook-Token: your_secret_here
# Generate: openssl rand -hex 32
# WEBHOOK_SECRET=


# ---------------------------------------------------------------------------
# Tier 1: Core — severity thresholds (no DB required)
# ---------------------------------------------------------------------------

# Global floor: suppress all alerts below this severity.
# Valid values: info (pass all), warning (suppress info), critical (suppress info+warning).
# Default: info (everything passes through).
# MIN_SEVERITY=info

# Per-service override — upper-case service name, non-alphanumeric → underscore.
# Same valid values as MIN_SEVERITY: info, warning, critical.
# Per-service thresholds can be set lower than MIN_SEVERITY (more permissive).
# THRESHOLD_NGINX=warning
# THRESHOLD_MY_SERVER=critical

# Quiet hours — suppress non-critical alerts during off-hours.
# Format: HH:MM-HH:MM (24-hour). Wraps around midnight (22:00-08:00 = 10pm to 8am).
# QUIET_HOURS=22:00-08:00
# During quiet hours, only alerts at or above this severity are dispatched.
# Valid values: info, warning, critical. Default: critical.
# QUIET_HOURS_MIN_SEVERITY=critical

# Metric thresholds — suppress alerts where a numeric value is below the threshold.
# Format: METRIC_THRESHOLD_{METRIC_NAME}={value}
# The metric name is extracted from alert details (e.g., memory_percent, cpu_percent).
# Alerts with a metric value below the threshold are suppressed as noise.
# METRIC_THRESHOLD_MEMORY_PERCENT=95
# METRIC_THRESHOLD_CPU_PERCENT=90
# METRIC_THRESHOLD_DISK_PERCENT=85


# ---------------------------------------------------------------------------
# Tier 1: Core — dedup (L1 in-memory, no DB required)
# ---------------------------------------------------------------------------
# Suppress identical alerts within this window (seconds).
# Identical = same service + status + message. Set to 0 to disable.
# L1 (in-memory per-worker) always works. L2 (cross-worker, survives restarts)
# requires DB.
# DEDUP_TTL_SECONDS=60


# ---------------------------------------------------------------------------
# Tier 1: Core — storm intelligence (no DB required for buffering)
# ---------------------------------------------------------------------------
# Buffer alerts during a window and send one combined analysis if threshold met.
# Recovery alerts always bypass the buffer. Buffering is in-memory per-worker.
# Incident creation during storm flush requires DB (silently skipped without DB).
# STORM_WINDOW=0
# STORM_THRESHOLD=3


# ---------------------------------------------------------------------------
# Tier 1: Core — AI provider selection (no DB required)
# ---------------------------------------------------------------------------
# Three providers: gemini (default), anthropic (Claude), openai (any OpenAI-compatible API).
# "openai" is a universal connector — OpenAI, Grok, Groq, Ollama, LM Studio, llama.cpp, vLLM, etc.
# AI_PROVIDER=gemini

# Anthropic (Claude) — set AI_PROVIDER=anthropic to activate.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_RPM=0
# ANTHROPIC_TIMEOUT=30

# OpenAI-compatible provider — set AI_PROVIDER=openai to activate.
# One config covers ALL OpenAI-compatible APIs. Just change the base URL,
# key, and model. Works with: OpenAI (GPT-4o, o3), Grok (xAI), Groq,
# Ollama, LM Studio, llama.cpp, vLLM, OpenClaw, and any other provider
# that exposes a /v1/chat/completions endpoint.
#
# Local (API key can be any non-empty string):
#   Ollama:    OPENAI_BASE_URL=http://192.168.1.x:11434/v1   OPENAI_API_KEY=ollama      OPENAI_MODEL=qwen2.5:latest
#   LM Studio: OPENAI_BASE_URL=http://192.168.1.x:1234/v1    OPENAI_API_KEY=lm-studio   OPENAI_MODEL=your-model
#   llama.cpp: OPENAI_BASE_URL=http://192.168.1.x:8080/v1    OPENAI_API_KEY=unused      OPENAI_MODEL=default
#   vLLM:      OPENAI_BASE_URL=http://192.168.1.x:8000/v1    OPENAI_API_KEY=unused      OPENAI_MODEL=your-model
#   OpenClaw:  OPENAI_BASE_URL=http://192.168.1.x:18789/v1   OPENAI_API_KEY=openclaw    OPENAI_MODEL=your-model
#
# Cloud:
#   OpenAI:  OPENAI_BASE_URL=https://api.openai.com/v1       OPENAI_API_KEY=sk-...    OPENAI_MODEL=gpt-4o
#   Grok:    OPENAI_BASE_URL=https://api.x.ai/v1             OPENAI_API_KEY=xai-...   OPENAI_MODEL=grok-3-mini
#   Groq:    OPENAI_BASE_URL=https://api.groq.com/openai/v1  OPENAI_API_KEY=gsk_...   OPENAI_MODEL=llama-3.3-70b-versatile
#
# OPENAI_BASE_URL=
# OPENAI_API_KEY=
# OPENAI_MODEL=
# OPENAI_RPM=0
# OPENAI_TIMEOUT=30

# Provider failover — if the primary AI_PROVIDER fails (429, 5xx, connection
# error), Sentinel automatically tries this fallback provider. Great for
# ensuring alert enrichment during a storm when Gemini is rate-limited:
#   AI_PROVIDER=gemini
#   AI_PROVIDER_FALLBACK=openai  (pointing at local Ollama)
# AI_PROVIDER_FALLBACK=

# Gemini model name
# GEMINI_MODEL=gemini-2.5-flash

# Gemini RPM (requests per minute) limiter.
# Default 10 matches the free tier limit. Set to 0 to disable.
# GEMINI_RPM=10

# Retry on 429 / 5xx from the Gemini API (default: 2 retries).
# GEMINI_RETRIES=2
# GEMINI_RETRY_BACKOFF=1.0

# AI backpressure — limit concurrent AI calls to prevent thread starvation.
# When all slots are busy for > 2s, returns a fallback response. No DB required.
# Default 4 ensures at least 8 of 12 worker threads (3 workers x 4 threads)
# stay available for webhook processing during an AI flood. Set to 0 to disable.
# AI_CONCURRENCY=4

# Maximum prompt characters sent to the AI per call (default: 12000, ~3000 tokens).
# Lower = cheaper. Floor of 2000 ensures the core template fits.
# MAX_PROMPT_CHARS=12000


# ---------------------------------------------------------------------------
# Tier 1: Core — topology and runbooks (no DB required, filesystem only)
# ---------------------------------------------------------------------------
# Topology mapping — YAML file describing service dependencies.
# Used by the AI for cascade analysis. Correlation engine also uses it but
# requires DB (open incidents) in addition to the topology file.
# TOPOLOGY_FILE=

# Runbooks — markdown files with service-specific remediation steps.
# The AI includes these in its suggested actions.
# Default directory: /data/runbooks/
# RUNBOOK_DIR=


# ---------------------------------------------------------------------------
# Tier 1: Core — watchdog heartbeat (no DB required)
# ---------------------------------------------------------------------------
# Periodic ping to an external monitoring endpoint. If Sentinel hangs/crashes,
# the missed heartbeat alerts you. Works with Healthchecks.io, Uptime Kuma, etc.
# WATCHDOG_URL=
# WATCHDOG_INTERVAL=300


# ---------------------------------------------------------------------------
# Tier 1: Core — Gunicorn performance (no DB required)
# ---------------------------------------------------------------------------
# WORKERS=3
# WORKER_THREADS=4
# GUNICORN_MAX_REQUESTS=1000
# GUNICORN_TIMEOUT=60
# GUNICORN_ACCESS_LOG=
PORT=5000


# ===========================================================================
# Tier 2: DB-dependent features (requires DB_PATH set to a writable path)
# ===========================================================================
# IMPORTANT: All features in this section require the DB. If DB_PATH is not
# set or DB_DISABLED=true, these features are automatically and silently
# disabled — no need to comment them out individually.

# Explicitly disable the DB (and ALL Tier 2/3 features at once):
# DB_DISABLED=true

# Path inside the container. Mapped to the sentinel-data named volume.
# DB_PATH=/data/sentinel.db

# Webhook rate limiter — sliding window counter. REQUIRES DB.
# Without DB: all requests are allowed through (limiter silently inactive).
# WEBHOOK_RATE_LIMIT=0
# WEBHOOK_RATE_WINDOW=60

# Per-service notification cooldown. REQUIRES DB.
# Without DB: no cooldown applied (all alerts dispatch immediately).
# COOLDOWN_SECONDS=0

# Severity escalation — auto-escalate repeated warnings to critical. REQUIRES DB.
# Without DB: warnings never auto-escalate.
# ESCALATION_THRESHOLD=0
# ESCALATION_WINDOW=3600

# Dead letter queue — retry failed notifications. REQUIRES DB.
# Without DB: failed dispatches are lost.
# DLQ_MAX_RETRIES=3

# Housekeeper — auto-pruning and WAL checkpointing. REQUIRES DB.
# Without DB: housekeeper does not start.
# RETENTION_DAYS=90
# HOUSEKEEP_INTERVAL=86400

# Alert history for AI context. REQUIRES DB.
# Without DB: predictive mode works but has no history to inject.
# ALERT_HISTORY_LIMIT=5
# ALERT_HISTORY_HOURS=0


# ===========================================================================
# Tier 3: Web UI (requires DB)
# ===========================================================================
# The web UI stores sessions, incidents, and alert history in SQLite.
# It requires a working DB (DB_PATH set, DB_DISABLED not true).
# Session auth is completely independent from webhook HMAC (WEBHOOK_SECRET).
#
# PASSWORD SETUP — two options:
#   Option A: Set UI_PASSWORD here (easiest, works immediately)
#   Option B: Leave UI_PASSWORD unset, open the UI in a browser, and
#             set your password on the first-run setup screen. The
#             password is hashed (scrypt) and stored in the DB.
# Either way, the password must be at least 8 characters.
#
# Threat model addition: exposes /api/* endpoints with session cookie auth,
# SSE real-time stream, and a React SPA. Attack surface increases compared
# to Tier 1/2 (webhook-only).
#
# UI_PASSWORD=your-ui-password-here
